#!/usr/bin/env bash
# ~/.local/bin/fuzzel-files — Search files using fd + fuzzel (optimized)

IGNORE_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/fuzzel/fuzzel-files-ignore"

# Truncate long paths: keep first 3 and last 2 components, replace middle with ...
shorten_path() {
    awk -F/ '{
        if(NF>6) {
            printf "%s/%s/%s/.../%s/%s\n", $1, $2, $3, $(NF-1), $NF
        } else {
            print
        }
    }'
}

# Search both $HOME and /mnt/data, with path shortening
{
    fd --type f --hidden --ignore-file "$IGNORE_FILE" --max-depth 5 . ~ 2>/dev/null \
        | sed "s|^$HOME/|~/|" \
        | shorten_path

    [ -d /mnt/data ] && fd --type f --hidden --ignore-file "$IGNORE_FILE" --max-depth 5 . /mnt/data 2>/dev/null \
        | sed 's|^/mnt/data/|DATA:|' \
        | shorten_path
} | fuzzel --dmenu --prompt="Files > " --lines 20 | {
    read -r line
    [ -z "$line" ] && exit 0

    # Expand shortened paths back
    line=$(echo "$line" | sed "s|^~|$HOME|" | sed "s|^DATA:|/mnt/data/|")

    xdg-open "$line"
}
