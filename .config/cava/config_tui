[general]
framerate = 75
autosens = 1
# 固定为 24 条，确保长度不变
bars = 24
bar_spacing = 0
bar_width = 1

[input]
method = pipewire
source = auto

[output]
method = ncurses
raw_target = /dev/stdout
;data_format = ascii
ascii_max_range = 7

[smoothing]
integral = 85
monstercat = 1
waves = 0
gravity = 120
ignore = 0

[color]
gradient = 1
gradient_count = 8
gradient_color_1 = '#a3c9ff'
gradient_color_2 = '#005da6'
gradient_color_3 = '#bcc5eb'
gradient_color_4 = '#515a7b'
gradient_color_5 = '#c4c1f9'
gradient_color_6 = '#585687'
gradient_color_7 = '#ffb4ab'
gradient_color_8 = '#b61718'
