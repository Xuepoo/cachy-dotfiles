# ~/.config/fish/colors-template.fish
# Fish syntax highlighting colors compiled by Matugen

set -U fish_color_normal '#dde3ee'
set -U fish_color_command '#a1c9ff' --bold
set -U fish_color_param '#bbc6ea'
set -U fish_color_keyword '#c2c1f9' --bold
set -U fish_color_quote '#c2c1f9'
set -U fish_color_redirection '#a1c9ff'
set -U fish_color_end '#bbc6ea'
set -U fish_color_error '#ffb4ab' --bold
set -U fish_color_comment '#c1c7d2'
set -U fish_color_selection --background='#272d36'
set -U fish_color_search_match --background='#272d36'
set -U fish_color_operator '#a1c9ff'
set -U fish_color_escape '#c2c1f9'
set -U fish_color_autosuggestion '#565c66'

# Fish pager colors
set -U fish_pager_color_prefix '#a1c9ff' --bold
set -U fish_pager_color_completion '#dde3ee'
set -U fish_pager_color_description '#c1c7d2'
set -U fish_pager_color_progress '#bbc6ea'
