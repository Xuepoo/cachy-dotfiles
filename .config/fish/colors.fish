# ~/.config/fish/colors-template.fish
# Fish syntax highlighting colors compiled by Matugen

set -U fish_color_normal '#f9ddd3'
set -U fish_color_command '#ffb599' --bold
set -U fish_color_param '#f0bc95'
set -U fish_color_keyword '#efbe79' --bold
set -U fish_color_quote '#efbe79'
set -U fish_color_redirection '#ffb599'
set -U fish_color_end '#f0bc95'
set -U fish_color_error '#ffb4ab' --bold
set -U fish_color_comment '#dbc1b8'
set -U fish_color_selection --background='#392923'
set -U fish_color_search_match --background='#392923'
set -U fish_color_operator '#ffb599'
set -U fish_color_escape '#efbe79'
set -U fish_color_autosuggestion '#6b5750'

# Fish pager colors
set -U fish_pager_color_prefix '#ffb599' --bold
set -U fish_pager_color_completion '#f9ddd3'
set -U fish_pager_color_description '#dbc1b8'
set -U fish_pager_color_progress '#f0bc95'
