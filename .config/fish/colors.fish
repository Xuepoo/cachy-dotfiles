# ~/.config/fish/colors-template.fish
# Fish syntax highlighting colors compiled by Matugen

set -U fish_color_normal '#f6dce0'
set -U fish_color_command '#ffb1c4' --bold
set -U fish_color_param '#f5b7b3'
set -U fish_color_keyword '#ffb59b' --bold
set -U fish_color_quote '#ffb59b'
set -U fish_color_redirection '#ffb1c4'
set -U fish_color_end '#f5b7b3'
set -U fish_color_error '#ffb4ab' --bold
set -U fish_color_comment '#d9c0c5'
set -U fish_color_selection --background='#38282c'
set -U fish_color_search_match --background='#38282c'
set -U fish_color_operator '#ffb1c4'
set -U fish_color_escape '#ffb59b'
set -U fish_color_autosuggestion '#6a575a'

# Fish pager colors
set -U fish_pager_color_prefix '#ffb1c4' --bold
set -U fish_pager_color_completion '#f6dce0'
set -U fish_pager_color_description '#d9c0c5'
set -U fish_pager_color_progress '#f5b7b3'
