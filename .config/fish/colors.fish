# ~/.config/fish/colors-template.fish
# Fish syntax highlighting colors compiled by Matugen

set -U fish_color_normal '#e0e2ef'
set -U fish_color_command '#b1c5ff' --bold
set -U fish_color_param '#c4c3eb'
set -U fish_color_keyword '#cfbef6' --bold
set -U fish_color_quote '#cfbef6'
set -U fish_color_redirection '#b1c5ff'
set -U fish_color_end '#c4c3eb'
set -U fish_color_error '#ffb4ab' --bold
set -U fish_color_comment '#c4c6d3'
set -U fish_color_selection --background='#292c36'
set -U fish_color_search_match --background='#292c36'
set -U fish_color_operator '#b1c5ff'
set -U fish_color_escape '#cfbef6'
set -U fish_color_autosuggestion '#585b66'

# Fish pager colors
set -U fish_pager_color_prefix '#b1c5ff' --bold
set -U fish_pager_color_completion '#e0e2ef'
set -U fish_pager_color_description '#c4c6d3'
set -U fish_pager_color_progress '#c4c3eb'
