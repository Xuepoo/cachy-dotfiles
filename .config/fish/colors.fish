# ~/.config/fish/colors-template.fish
# Fish syntax highlighting colors compiled by Matugen

set -U fish_color_normal '#dfe2ef'
set -U fish_color_command '#aac7ff' --bold
set -U fish_color_param '#c0c4eb'
set -U fish_color_keyword '#c9bff8' --bold
set -U fish_color_quote '#c9bff8'
set -U fish_color_redirection '#aac7ff'
set -U fish_color_end '#c0c4eb'
set -U fish_color_error '#ffb4ab' --bold
set -U fish_color_comment '#c3c6d3'
set -U fish_color_selection --background='#282d36'
set -U fish_color_search_match --background='#282d36'
set -U fish_color_operator '#aac7ff'
set -U fish_color_escape '#c9bff8'
set -U fish_color_autosuggestion '#575b66'

# Fish pager colors
set -U fish_pager_color_prefix '#aac7ff' --bold
set -U fish_pager_color_completion '#dfe2ef'
set -U fish_pager_color_description '#c3c6d3'
set -U fish_pager_color_progress '#c0c4eb'
