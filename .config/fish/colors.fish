# ~/.config/fish/colors-template.fish
# Fish syntax highlighting colors compiled by Matugen

set -U fish_color_normal '#d8e5e9'
set -U fish_color_command '#00d9fd' --bold
set -U fish_color_param '#a8cbe2'
set -U fish_color_keyword '#a5caf5' --bold
set -U fish_color_quote '#a5caf5'
set -U fish_color_redirection '#00d9fd'
set -U fish_color_end '#a8cbe2'
set -U fish_color_error '#ffb4ab' --bold
set -U fish_color_comment '#bcc9cd'
set -U fish_color_selection --background='#232e32'
set -U fish_color_search_match --background='#232e32'
set -U fish_color_operator '#00d9fd'
set -U fish_color_escape '#a5caf5'
set -U fish_color_autosuggestion '#515e61'

# Fish pager colors
set -U fish_pager_color_prefix '#00d9fd' --bold
set -U fish_pager_color_completion '#d8e5e9'
set -U fish_pager_color_description '#bcc9cd'
set -U fish_pager_color_progress '#a8cbe2'
